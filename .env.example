# Analytics IDs — copy this file to ".env" and fill in your real IDs.
# These are exposed to the web bundle (EXPO_PUBLIC_ prefix) and used by
# src/analytics/analytics.ts. Leave blank to disable a provider.

# Google Analytics 4 Measurement ID (Admin > Data Streams > Web)
EXPO_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID (Events Manager > Data Sources)
EXPO_PUBLIC_META_PIXEL_ID=
