# --- Magasool mail backend configuration ---
# Copy this file to `.env` and fill in your real values.

# Port the API listens on (frontend defaults to http://localhost:3001)
PORT=3001

# Where enquiries are delivered
FARMER_NOTIFY_EMAIL=farmers@yourdomain.com
BUYER_NOTIFY_EMAIL=buyers@yourdomain.com

# "From" address shown on the emails
MAIL_FROM=Magasool <no-reply@yourdomain.com>

# --- SMTP credentials ---
# Leave SMTP_HOST blank to run in DEV mode (submissions are logged, not emailed).
# Examples:
#   Gmail:    host=smtp.gmail.com  port=465  secure=true  (use an App Password)
#   SendGrid: host=smtp.sendgrid.net port=587 secure=false user=apikey pass=<API_KEY>
#   Mailgun:  host=smtp.mailgun.org port=587 secure=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
